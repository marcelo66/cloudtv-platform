generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS & AUTH ────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  avatarUrl    String?  @map("avatar_url")
  role         Role     @default(USER)
  plan         Plan     @default(FREE)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  channels           Channel[]
  refreshTokens      RefreshToken[]
  youtubeCredential  YoutubeCredential?

  @@map("users")
}

// ─── YOUTUBE AUTH ─────────────────────────────────────────────
// Credenciales OAuth2 de YouTube obtenidas vía Device Authorization Flow.
// Almacena el contenido del directorio youtube-oauth2 del caché de yt-dlp
// como JSON { [filename]: contenido } para sobrevivir reinicios del container.

model YoutubeCredential {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // { [filename.json]: contenido } del dir youtube-oauth2 de yt-dlp
  tokenJson    String   @map("token_json")
  accountEmail String?  @map("account_email")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("youtube_credentials")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

// ─── CHANNEL ─────────────────────────────────────────────────

model Channel {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  slug         String        @unique
  description  String?
  logoUrl      String?       @map("logo_url")
  status       ChannelStatus @default(OFFLINE)
  streamKey    String        @unique @map("stream_key") @default(cuid())
  hlsUrl       String?       @map("hls_url")
  videoQuality      String        @default("480p") @map("video_quality")
  // Valores: 480p | 720p | 1080p
  // ─── Publicidad automática por intervalo ───────────────────
  adIntervalMinutes Int?          @map("ad_interval_minutes")
  adIntervalBlockId String?       @map("ad_interval_block_id")
  adIntervalBlock   AdBlock?      @relation("ChannelAdInterval", fields: [adIntervalBlockId], references: [id])
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  videos        Video[]
  playlists     Playlist[]
  overlays      Overlay[]
  schedules     Schedule[]
  outputs       StreamOutput[]
  ingestSources IngestSource[]
  logs          PlayoutLog[]
  adBlocks      AdBlock[]
  cuePoints     CuePoint[]
  adImpressions AdImpression[]

  @@map("channels")
}

// ─── VIDEOS ──────────────────────────────────────────────────

model Video {
  id            String      @id @default(cuid())
  channelId     String      @map("channel_id")
  channel       Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  status        VideoStatus @default(PENDING)
  originalKey   String      @map("original_key")
  processedKey  String?     @map("processed_key")
  thumbnailUrl  String?     @map("thumbnail_url")
  duration      Float?
  width         Int?
  height        Int?
  fps           Float?
  codec         String?
  bitrate       Int?
  fileSize      BigInt      @map("file_size")
  mimeType      String      @map("mime_type")
  tags          String[]    @default([])
  folder        String?     // Carpeta organizativa (solo filtrado en frontend)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  playlistItems PlaylistItem[]
  adSpots       AdSpot[]
  cuePoints     CuePoint[]

  @@map("videos")
}

// ─── PLAYLISTS ───────────────────────────────────────────────

model Playlist {
  id            String         @id @default(cuid())
  channelId     String         @map("channel_id")
  channel       Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  loopMode      LoopMode       @default(LOOP_ALL) @map("loop_mode")
  isDefault     Boolean        @default(false) @map("is_default")
  totalDuration Float?         @map("total_duration")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  items     PlaylistItem[]
  schedules Schedule[]

  @@map("playlists")
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String   @map("playlist_id")
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  videoId    String   @map("video_id")
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  order      Int
  trimStart  Float?   @map("trim_start")
  trimEnd    Float?   @map("trim_end")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([playlistId, order])
  @@map("playlist_items")
}

// ─── SCHEDULER ───────────────────────────────────────────────

model Schedule {
  id         String     @id @default(cuid())
  channelId  String     @map("channel_id")
  channel    Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  playlistId String?    @map("playlist_id")
  playlist   Playlist?  @relation(fields: [playlistId], references: [id])
  name       String
  startTime  DateTime   @map("start_time")
  endTime    DateTime   @map("end_time")
  recurrence    Recurrence @default(ONCE)
  priority      Int        @default(0)
  // ─── Tandas ancladas al programa ───────────────────────────
  preAdBlockId  String?    @map("pre_ad_block_id")
  postAdBlockId String?    @map("post_ad_block_id")
  preAdBlock    AdBlock?   @relation("SchedulePreAd",  fields: [preAdBlockId],  references: [id])
  postAdBlock   AdBlock?   @relation("SchedulePostAd", fields: [postAdBlockId], references: [id])
  createdAt     DateTime   @default(now()) @map("created_at")

  @@map("schedules")
}

// ─── OVERLAYS ────────────────────────────────────────────────

model Overlay {
  id        String      @id @default(cuid())
  channelId String      @map("channel_id")
  channel   Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String
  type      OverlayType
  enabled   Boolean     @default(true)
  config    Json
  zIndex    Int         @default(0) @map("z_index")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("overlays")
}

// ─── STREAM OUTPUTS ───────────────────────────────────────────

model StreamOutput {
  id        String       @id @default(cuid())
  channelId String       @map("channel_id")
  channel   Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String
  platform  Platform
  // RTMP: URL base del servidor. SRT_CALLER: host/IP de destino. SRT_LISTENER: ignorado.
  rtmpUrl   String       @default("") @map("rtmp_url")
  // RTMP: stream key. SRT: no se usa (vacío).
  streamKey String       @default("") @map("stream_key")
  enabled   Boolean      @default(true)
  status    OutputStatus @default(IDLE)
  // ── Campos exclusivos SRT ────────────────────────────────────────────────
  srtPort       Int?    @map("srt_port")       // Puerto SRT (default: 9001)
  srtLatency    Int?    @map("srt_latency")     // Latencia en milisegundos (default: 120 ms)
  srtPassphrase String? @map("srt_passphrase")  // Passphrase de cifrado AES (10-79 chars, opcional)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("stream_outputs")
}

// ─── INGEST SOURCES ──────────────────────────────────────────
// Fuentes de ingesta: reemplazan la programación normal para transmitir
// eventos en vivo (YouTube, SRT, RTMP entrante).

model IngestSource {
  id        String       @id @default(cuid())
  channelId String       @map("channel_id")
  channel   Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String
  type      IngestType
  // Dependiendo del tipo:
  //   YOUTUBE:      URL completa de YouTube Watch/Live
  //   SRT_CALLER:   "host:port" al que conectarse (ej: "10.10.0.5:9002")
  //   SRT_LISTENER: vacío — escucha en srtPort
  //   RTMP_PUSH:    vacío — escucha en rtmpPort con rtmpKey
  url           String   @default("")
  // SRT
  srtPort       Int?     @map("srt_port")
  srtLatency    Int?     @map("srt_latency")
  srtPassphrase String?  @map("srt_passphrase")
  // RTMP Push entrante
  rtmpPort      Int?     @map("rtmp_port")   // Puerto RTMP (default 1935)
  rtmpKey       String?  @map("rtmp_key")    // Stream key del encoder
  // Estado actual
  status    IngestStatus @default(IDLE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("ingest_sources")
}

// ─── AD BREAKS (Tandas Publicitarias) ────────────────────────

model AdBlock {
  id            String       @id @default(cuid())
  channelId     String       @map("channel_id")
  channel       Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  rotationMode  RotationMode @default(SEQUENTIAL) @map("rotation_mode")
  sequenceIndex Int          @default(0) @map("sequence_index")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  spots       AdSpot[]
  cuePoints   CuePoint[]
  impressions AdImpression[]
  // Reverse relations para intervalo de canal y tandas de programa
  intervalChannels Channel[]   @relation("ChannelAdInterval")
  preSchedules     Schedule[]  @relation("SchedulePreAd")
  postSchedules    Schedule[]  @relation("SchedulePostAd")

  @@map("ad_blocks")
}

model AdSpot {
  id         String   @id @default(cuid())
  adBlockId  String   @map("ad_block_id")
  adBlock    AdBlock  @relation(fields: [adBlockId], references: [id], onDelete: Cascade)
  videoId    String   @map("video_id")
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  name       String
  advertiser String
  weight     Int      @default(1)
  order      Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  impressions AdImpression[]

  @@map("ad_spots")
}

model CuePoint {
  id         String       @id @default(cuid())
  channelId  String       @map("channel_id")
  channel    Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  videoId    String       @map("video_id")
  video      Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  adBlockId  String       @map("ad_block_id")
  adBlock    AdBlock      @relation(fields: [adBlockId], references: [id], onDelete: Cascade)
  type       CuePointType
  timeOffset Float?       @map("time_offset")
  isActive   Boolean      @default(true) @map("is_active")
  label      String?      // Etiqueta descriptiva opcional
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@map("cue_points")
}

model AdImpression {
  id          String       @id @default(cuid())
  adSpotId    String       @map("ad_spot_id")
  adSpot      AdSpot       @relation(fields: [adSpotId], references: [id], onDelete: Cascade)
  adBlockId   String       @map("ad_block_id")
  adBlock     AdBlock      @relation(fields: [adBlockId], references: [id], onDelete: Cascade)
  channelId   String       @map("channel_id")
  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  advertiser  String
  type        CuePointType
  duration    Float?
  scheduledAt DateTime     @default(now()) @map("scheduled_at")

  @@map("ad_impressions")
}

// ─── PLAYOUT LOGS ─────────────────────────────────────────────

model PlayoutLog {
  id        String   @id @default(cuid())
  channelId String   @map("channel_id")
  channel   Channel  @relation(fields: [channelId], references: [id])
  event     String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("playout_logs")
}

// ─── ENUMS ────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum ChannelStatus {
  OFFLINE
  LIVE_PLAYLIST
  LIVE_RTMP
  STARTING
  ERROR
}

enum VideoStatus {
  PENDING
  PROCESSING
  READY
  ERROR
  ARCHIVED
}

enum LoopMode {
  LOOP_ALL
  LOOP_ONE
  SEQUENTIAL
}

enum Recurrence {
  ONCE
  DAILY
  WEEKLY
  WEEKDAYS
  WEEKENDS
}

enum OverlayType {
  LOGO
  TEXT_STATIC
  TEXT_SCROLL
  CLOCK
  TICKER
}

enum IngestType {
  YOUTUBE      // Fuente YouTube live (requiere yt-dlp instalado)
  SRT_CALLER   // Conectarse a una fuente SRT remota (cliente con ZeroTier u otro)
  SRT_LISTENER // Escuchar conexiones SRT entrantes en un puerto local
  RTMP_PUSH    // Recibir RTMP push de un encoder (OBS, vMix, etc.)
}

enum IngestStatus {
  IDLE    // No activo
  ACTIVE  // El playout está usando esta fuente como señal en vivo
  ERROR   // El proceso FFmpeg terminó con error
}

enum Platform {
  YOUTUBE
  FACEBOOK
  TWITCH
  RTMP_CUSTOM
  SRT_CALLER    // Enviar SRT a un destino conocido (cablera, encoder remoto, peer ZeroTier)
  SRT_LISTENER  // Escuchar conexiones SRT entrantes en un puerto local
}

enum OutputStatus {
  IDLE
  STREAMING
  ERROR
}

enum RotationMode {
  SEQUENTIAL
  RANDOM
  WEIGHTED
}

enum CuePointType {
  PRE_ROLL
  MID_ROLL
  POST_ROLL
}
