# ════════════════════════════════════════════════════════════
#  CloudTV — Variables de entorno PRODUCCIÓN
#  Copiá este archivo a .env y completá los valores marcados ←
# ════════════════════════════════════════════════════════════

# ─── Tu dominio o IP del servidor ───────────────────────────
# Ejemplo: https://tv.midominio.com  o  http://123.456.789.0
APP_URL=https://TU_DOMINIO_AQUI        # ← CAMBIAR

SERVER_HOST=TU_IP_O_DOMINIO            # ← CAMBIAR (sin https://)

# ─── Base de datos ──────────────────────────────────────────
POSTGRES_DB=cloudtv
POSTGRES_USER=cloudtv_user
POSTGRES_PASSWORD=CambiarEstoPorUnaClaveSegura123!   # ← CAMBIAR

# ─── Cola de trabajos ───────────────────────────────────────
REDIS_PASSWORD=OtraClaveSeguraParaRedis456!          # ← CAMBIAR

# ─── Seguridad JWT ──────────────────────────────────────────
# Generá claves aleatorias en: https://generate-secret.vercel.app/64
JWT_SECRET=pegar_aqui_clave_aleatoria_larga_1        # ← CAMBIAR
JWT_REFRESH_SECRET=pegar_aqui_clave_aleatoria_larga_2 # ← CAMBIAR

# ─── Storage de videos (MinIO) ──────────────────────────────
MINIO_ROOT_USER=cloudtvadmin
MINIO_ROOT_PASSWORD=ClaveDeMinioSegura789!           # ← CAMBIAR
R2_BUCKET=cloudtv-storage

# ─── FFmpeg ─────────────────────────────────────────────────
# Cuántos núcleos de CPU usar para procesar video
# Poné la mitad de los núcleos de tu servidor
FFMPEG_THREADS=2
FFMPEG_PRESET=veryfast
