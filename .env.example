# ─── APP ──────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost

# ─── DATABASE ─────────────────────────────────────────────────
POSTGRES_DB=cloudtv
POSTGRES_USER=cloudtv_user
POSTGRES_PASSWORD=cloudtv_dev_password_change_in_prod
DATABASE_URL=postgresql://cloudtv_user:cloudtv_dev_password_change_in_prod@localhost:5432/cloudtv

# ─── REDIS ────────────────────────────────────────────────────
REDIS_PASSWORD=redis_dev_password
REDIS_URL=redis://:redis_dev_password@localhost:6379

# ─── JWT ──────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=dev_jwt_secret_minimum_32_characters_long_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_minimum_32_chars_different_from_above
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CLOUDFLARE R2 (o MinIO en dev) ──────────────────────────
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key
R2_SECRET_ACCESS_KEY=tu_secret_key
R2_BUCKET=cloudtv-storage
R2_PUBLIC_URL=http://localhost:9000/cloudtv-storage
# Para dev local con MinIO:
# R2_ENDPOINT=http://localhost:9000

# ─── FFMPEG ───────────────────────────────────────────────────
FFMPEG_THREADS=2
FFMPEG_PRESET=veryfast

# ─── MEDIAMTX ─────────────────────────────────────────────────
MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_RTMP_URL=rtmp://localhost:1935

# ─── INTERNAL ─────────────────────────────────────────────────
INTERNAL_API_SECRET=internal_secret_for_mediamtx_hooks
